        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--color-text-primary);
        margin: 0 0 1.5rem 0;
        line-height: 1.2;
      }
      .summary {
        font-size: 1.25rem;
        color: var(--color-text-secondary);
        line-height: 1.6;
        margin-bottom: 2rem;
